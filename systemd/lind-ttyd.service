[Unit]
Description=Lind — ttyd terminal exposing Cline CLI
After=network.target

[Service]
Type=simple
User=exis
WorkingDirectory=/opt/lind
EnvironmentFile=/opt/lind/.env
ExecStart=/usr/local/bin/ttyd --port 7681 --interface 127.0.0.1 --writable /opt/lind/cline_launcher.sh
Restart=always
RestartSec=5

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/opt/lind
ReadOnlyPaths=/opt/lind/node_modules

[Install]
WantedBy=multi-user.target
